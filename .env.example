# Neon pooled connection string (used by the running app), e.g. postgresql://user:pass@host-pooler/db?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/solar_ims?schema=public"

# Neon direct (unpooled) connection string — required for `prisma migrate deploy`/`migrate dev`.
# For local Postgres this can be identical to DATABASE_URL.
DIRECT_URL="postgresql://user:password@localhost:5432/solar_ims?schema=public"

# Random secret used to sign NextAuth JWTs. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Base URL of the deployment (used for auth callbacks)
NEXTAUTH_URL="http://localhost:3000"

# Credentials the seed script uses to create the Super Admin account
SEED_SUPERADMIN_EMAIL=""
SEED_SUPERADMIN_PASSWORD=""
